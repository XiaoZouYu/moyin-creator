# Local PostgreSQL used by docker-compose.yml. Docker downloads the postgres
# image automatically when it is missing locally.
POSTGRES_DB=moyin_creator
POSTGRES_USER=moyin
POSTGRES_PASSWORD=change_me_local_password
POSTGRES_PORT=5432
DATABASE_URL=postgresql://moyin:change_me_local_password@127.0.0.1:5432/moyin_creator
CLOUD_STORAGE_TABLE=moyin_user_storage

# Aliyun OSS for generated/uploaded media files.
ALI_OSS_BUCKET=santisaas
ALI_OSS_REGION=oss-cn-chengdu
ALI_OSS_PREFIX=mj/
ALI_OSS_ACCESS_KEY_ID=your_access_key_id
ALI_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALI_OSS_SIGNED_URL_EXPIRES=86400

# Upload limits.
MAX_CLOUD_BODY_BYTES=209715200
